# Backend API base URL (empty string = same origin)
VITE_API_BASE=
# Agent Framework backend URL
VITE_AF_BACKEND_URL=/af
# Agent name for the Agent Framework
VITE_AGENT_NAME=talentiq-agent

# Demo mode — bypass MSAL entirely (for environments without an Entra app registration).
# When "true", main.jsx skips MsalProvider, App.jsx treats the user as a synthetic
# "Demo User", and outbound API calls omit the Authorization header. The backend's
# auth.py short-circuits to a "dev-user" when AZURE_TENANT_ID is unset.
# See talent_infra_modules/AUTH-DISABLED.md. Default (production) is "false".
VITE_DISABLE_AUTH=false

# MSAL / Entra ID
VITE_MSAL_CLIENT_ID=your-client-id
VITE_MSAL_AUTHORITY=https://login.microsoftonline.com/your-tenant-id
VITE_MSAL_REDIRECT_URI=http://localhost:5173
VITE_FOUNDRY_API_SCOPE=api://your-client-id/.default
VITE_BACKEND_API_SCOPE=

# Application Insights
VITE_APPINSIGHTS_CONNECTION_STRING=
