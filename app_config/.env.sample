# TalentIQ Foundry - Environment Configuration (SAMPLE)
# Copy this file to `.env` and replace placeholder values with real ones.
# Authentication: Uses DefaultAzureCredential (az login locally, MSI in Azure)

# Azure AI Search
AZURE_SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net
AZURE_SEARCH_CANDIDATES_INDEX=candidates-index
AZURE_SEARCH_DEMANDS_INDEX=demands-index

# Azure Cosmos DB
COSMOS_ENDPOINT=https://<your-cosmos-account>.documents.azure.com:443/
COSMOS_DATABASE=talentiq
COSMOS_CANDIDATES_CONTAINER=candidates
COSMOS_DEMANDS_CONTAINER=demands

# Foundry Enterprise Memory (Cosmos DB - for chat history)
FOUNDRY_COSMOS_ENDPOINT=https://<your-cosmos-account>.documents.azure.com:443/
FOUNDRY_COSMOS_DATABASE=enterprise_memory
FOUNDRY_COSMOS_CONTAINER=<your-foundry-run-state-container>

# Microsoft Foundry
FOUNDRY_ENDPOINT=https://<your-ai-services>.services.ai.azure.com/api/projects/<your-project>/openai/v1/responses
FOUNDRY_DEPLOYMENT=<your-foundry-deployment-name>

# Infra module deployment defaults
AZURE_SUBSCRIPTION_ID=<your-subscription-id-guid>
AZURE_RESOURCE_GROUP=<your-app-resource-group>
AZURE_LOCATION=westus
AZURE_ACR_NAME=<your-acr-name>
# Prefer AZURE_ACA_ENV_ID when the Container Apps environment is shared or in another RG.
AZURE_ACA_ENV_ID=/subscriptions/<your-subscription-id-guid>/resourceGroups/<your-aca-env-rg>/providers/Microsoft.App/managedEnvironments/<your-aca-env-name>
AZURE_ACA_ENV_NAME=<your-aca-env-name>
AZURE_ACA_ENV_RESOURCE_GROUP=<your-aca-env-rg>
BACKEND_CONTAINER_APP_NAME=<your-backend-container-app-name>
FOUNDRY_ACCOUNT_NAME=<your-ai-services-account-name>
FOUNDRY_PROJECT_NAME=<your-foundry-project-name>
FOUNDRY_CHAT_DEPLOYMENT_NAME=gpt-4.1

# Azure OpenAI Embeddings
AZURE_OPENAI_ENDPOINT=https://<your-ai-services>.cognitiveservices.azure.com/
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002
AZURE_OPENAI_EMBEDDING_DIMENSIONS=1536
AZURE_OPENAI_USE_ENTRA_AUTH=false
FOUNDRY_DEPLOYMENT_KEY=<your-foundry-deployment-key>
# AZURE_OPENAI_API_KEY=<your-azure-openai-api-key>
# FOUNDRY_API_KEY=<your-foundry-api-key>

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Foundry Agent Config (used by backend agent router)
foundry_account_name=<your-ai-services-account-name>
foundry_project_name=<your-foundry-project-name>
agent_name=<your-agent-name>

# Entra ID Tenant (required for agent chat token validation)
AZURE_TENANT_ID=<your-tenant-id-guid>

# Service Principal (only for CI/CD - uncomment and fill)
# AZURE_CLIENT_ID is reserved by DefaultAzureCredential — do NOT set here
# Use ENTRA_SPA_CLIENT_ID for backend JWT audience validation
ENTRA_SPA_CLIENT_ID=<your-spa-client-id-guid>
AZURE_TOKEN_AUDIENCE=https://ai.azure.com
# AZURE_CLIENT_SECRET=<your-client-secret>

# PostgreSQL Database (Azure Flexible Server + Apache AGE)
PGHOST=<your-postgres-server>.postgres.database.azure.com
PGPORT=5432
PGDATABASE=postgres
PGUSER=<your-postgres-admin-user>
PGPASSWORD=<your-postgres-password>
PGSSLMODE=require
PG_SERVER_NAME=<your-postgres-server-name>

# Graph Workflow (af-backend → MCP → AGE)
GRAPH_NAME=talent_graph_dev
MCP_ENDPOINT=http://localhost:3002/mcp
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=<your-chat-deployment-name>

# Application Insights (telemetry)
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=<your-instrumentation-key>;IngestionEndpoint=https://<region>.in.applicationinsights.azure.com/;LiveEndpoint=https://<region>.livediagnostics.monitor.azure.com/;ApplicationId=<your-application-id>

# Cosmos DB Chat History
COSMOS_CHAT_ENDPOINT=https://<your-cosmos-account>.documents.azure.com:443/
COSMOS_CHAT_DATABASE=talent_db
COSMOS_CHAT_CONTAINER=chat_history_db
